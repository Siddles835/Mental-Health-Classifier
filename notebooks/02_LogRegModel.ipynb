rint(randomized_search.best_params_)\n","\n","print(\"\\nBest crossval score:\")\n","print(randomized_search.best_score_)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"chqiOr8gFBVB","executionInfo":{"status":"ok","timestamp":1784139681944,"user_tz":240,"elapsed":3581305,"user":{"displayName":"Shubham Roy-Choudhury","userId":"13982725443816793205"}},"outputId":"2425436e-4d1d-4878-e306-a3400c21f8e6"},"execution_count":6,"outputs":[{"output_type":"stream","name":"stdout","text":["Best params:\n","{'tfidf__use_idf': False, 'tfidf__sublinear_tf': False, 'tfidf__stop_words': None, 'tfidf__norm': None, 'tfidf__ngram_range': (1, 2), 'tfidf__min_df': 2, 'tfidf__max_features': 40000, 'tfidf__max_df': 0.85, 'tfidf__binary': True, 'logreg__solver': 'liblinear', 'logreg__penalty': 'l2', 'logreg__C': 0.1}\n","\n","Best crossval score:\n","0.7609441226941657\n"]}]},{"cell_type":"code","source":["#predictions\n","\n","best_model = randomized_search.best_estimator_\n","\n","y_pred = best_model.predict(X_test)\n","\n","y_prob = best_model.predict_proba(X_test)"],"metadata":{"id":"znbEfD3s2JJF","executionInfo":{"status":"ok","timestamp":1784135589109,"user_tz":240,"elapsed":5409,"user":{"displayName":"Shubham Roy-Choudhury","userId":"13982725443816793205"}}},"execution_count":8,"outputs":[]},{"cell_type":"code","source":["#eval\n","\n","from sklearn.metrics import classification_report\n","\n","print(classification_report(y_test,y_pred,target_names=encoder.classes_))\n","\n","from sklearn.metrics import confusion_matrix\n","print(confusion_matrix(y_test, y_pred))"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"reJKyW8j2LPl","executionInfo":{"status":"ok","timestamp":1784135592586,"user_tz":240,"elapsed":28,"user":{"displayName":"Shubham Roy-Choudhury","userId":"13982725443816793205"}},"outputId":"ccb1367a-c437-41b9-836e-0a17603b60db"},"execution_count":9,"outputs":[{"output_type":"stream","name":"stdout","text":["                      precision 